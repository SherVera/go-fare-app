# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored. Never commit real secrets.
#
# Firebase config is NOT here: RN Firebase reads everything from
# GoogleService-Info.plist (iOS) and google-services.json (Android)
# at native startup, so no JS-side firebaseConfig is needed.
#
# For EAS builds, mirror these in EAS env vars / `eas.json` env section
# instead of relying on the local `.env` file.

# ─── Google Maps (iOS) ────────────────────────────────────────────────────
# Restrict this key in Google Cloud Console by bundle ID (com.gofare.app).
# Optional until you build iOS with MapView; without it, the map may fail on device.
GOOGLE_MAPS_IOS_API_KEY=

# ─── Backend API ──────────────────────────────────────────────────────────
# Base URL for your backend (used by future src/lib/api.ts helpers).
EXPO_PUBLIC_API_URL=

# ─── EAS ──────────────────────────────────────────────────────────────────
EAS_PROJECT_ID=1e738e60-7dd4-48be-b8f6-dd713dee3b67
