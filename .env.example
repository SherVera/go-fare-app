# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored. Never commit real secrets.
#
# Firebase (iOS / Android) — NOT in git
# Download from Firebase Console → Project settings → Your apps, then place at repo root:
#   GoogleService-Info.plist
#   google-services.json
# Required for native builds / @react-native-firebase. EAS: inject these files in the build environment
# (e.g. secret files or your CI step) so they exist before `eas build` reads app.config.

# ─── Google Maps (iOS) ────────────────────────────────────────────────────
# Restrict this key in Google Cloud Console by bundle ID (com.gofare.app).
# Optional until you build iOS with MapView; without it, the map may fail on device.
GOOGLE_MAPS_IOS_API_KEY=

# ─── Backend API ──────────────────────────────────────────────────────────
# Base URL for your backend (used by src/lib/api.ts). No trailing slash.
# Dev example: https://go-fare-backend-1.onrender.com
EXPO_PUBLIC_API_URL=

# ─── Google Sign-In ───────────────────────────────────────────────────────
# Web Client ID from Firebase Console → Authentication → Sign-in providers → Google.
# After enabling Google Sign-In, re-download google-services.json y GoogleService-Info.plist.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ─── iOS local device (Personal Team, no paid Apple Developer) ───────────
# Strips Push Notifications entitlements so Xcode can sign with a free account.
# Push/FCM will not work on that build. Remove or set to 0 for EAS/production.
IOS_PERSONAL_TEAM_BUILD=

# ─── EAS ──────────────────────────────────────────────────────────────────
EAS_PROJECT_ID=1e738e60-7dd4-48be-b8f6-dd713dee3b67

# ─── AI Commits (optional) ────────────────────────────────────────────────
# Used by `npm run commit:ai` (aicommits). Keep this only in local `.env`.
OPENAI_API_KEY=
